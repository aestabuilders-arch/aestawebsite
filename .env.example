# Next.js
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production: https://aesta.co.in

# Supabase (hosted project; see .mcp.json for MCP server config)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Service-role key (server-only; required by utils/supabase/admin.ts in later plans)
SUPABASE_SERVICE_ROLE_KEY=

# Business identity (consumed by lib/constants/nap.ts)
NEXT_PUBLIC_BUSINESS_NAME="AESTA — Architects & Builders"
NEXT_PUBLIC_BUSINESS_PHONE=+91-9176137043
NEXT_PUBLIC_BUSINESS_EMAIL=aestabuilders@gmail.com
NEXT_PUBLIC_BUSINESS_WHATSAPP=+91-9176137043

# Search-engine ownership verification (consumed by app/[locale]/layout.tsx).
# Paste only the token value, not the full meta tag. Leave blank to omit the tag.
# Google: Search Console > Settings > Ownership verification > HTML tag (content="...").
GOOGLE_SITE_VERIFICATION=
# Bing: Webmaster Tools > Verify > Meta tag (content of msvalidate.01).
BING_SITE_VERIFICATION=

# Social profile URLs surfaced in Organization schema sameAs (comma-separated).
# Add the Google Business Profile, Instagram, Facebook, etc. once they exist.
NEXT_PUBLIC_SOCIAL_PROFILES=

# IndexNow: key file is public/<key>.txt; the key below must match the filename.
# Used to notify Bing/Yandex of new/changed URLs. Pinging is manual for now.
# Current key file: public/154ab2f087eb1ad1598c13543d71bf29.txt
